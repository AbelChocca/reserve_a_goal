generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
//
// ENUMS
//
enum UserRole {
  USER 
  ADMIN_LOCAL
  SUPER_ADMIN
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

// USER
model User {
  id String @id @default(cuid())

  email String @unique
  name String
  passwordHash String
  role UserRole @default(USER)

  createdAt DateTime @default(now()) @db.Timestamptz
  updateAt DateTime @updatedAt

  bookings Booking[]
  locations Location[]
}


// LOCATION
model Location {
  id String @id @default(cuid())

  name String
  city String?
  address String?

  userId String
  user User @relation(fields: [userId], references: [id])

  spaces Space[]

  createAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// SPACE
model Space {
  id String @id @default(cuid())
  name String

  localId String
  location Location @relation(fields: [localId], references: [id])

  slotRules SlotRule[]
  bookings Booking[]
}

// SLOTRULE
model SlotRule {
  id String @id @default(cuid())

  spaceId String
  space Space @relation(fields: [spaceId], references: [id])

  dayOfWeek DayOfWeek

  startTime String
  endTime String

  slotMinutes Int

  isActive Boolean @default(true)

  @@unique([spaceId, dayOfWeek])
}

// BOOKING
model Booking {
  id String @id @default(cuid())

  spaceId String
  space Space @relation(fields: [spaceId], references: [id])

  userId String
  user User @relation(fields: [userId], references: [id])

  status BookingStatus @default(CONFIRMED)

  createdAt DateTime @default(now())
}